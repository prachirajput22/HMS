<!-- Top Navigation Bar -->
<header class="topbar">
  <div class="topbar-left">
    <button class="hamburger" onclick="toggleSidebar()" aria-label="Toggle sidebar">
      <i class="fas fa-bars"></i>
    </button>
    <div class="topbar-title">
      <h2><%= title %></h2>
      <p>Madhav Institute of Technology and Science</p>
    </div>
  </div>
  <div class="topbar-right">
    <% if (typeof admin === 'undefined') { %>
    <div class="topbar-search">
      <i class="fas fa-search"></i>
      <input type="text" placeholder="Search..." />
    </div>
    <% } %>

    <% if (typeof notifications !== 'undefined' && typeof unreadCount !== 'undefined') { %>
    <div class="notif-bell-wrapper" style="position:relative;">
      <button class="notif-bell" id="notifBellBtn" onclick="toggleNotifDropdown()" aria-label="Notifications">
        <i class="fas fa-bell"></i>
        <span class="notif-badge" id="notifBadge" style="<%= unreadCount > 0 ? '' : 'display:none;' %>"><%= unreadCount %></span>
      </button>
      <div class="notif-dropdown" id="notifDropdown">
        <div class="notif-dropdown-header" style="display:flex;align-items:center;justify-content:space-between;">
          <span><i class="fas fa-bell"></i> Notifications</span>
          <% if (typeof user !== 'undefined') { %>
            <a href="/notifications" style="font-size:0.78rem;color:var(--primary);text-decoration:none;">View All</a>
          <% } %>
        </div>
        <% if (notifications.length === 0) { %>
          <div class="notif-item"><span class="notif-msg" style="color:var(--text-muted);">No notifications yet.</span></div>
        <% } else { %>
          <% notifications.forEach(n => { %>
            <% const isRead = n.userId ? n.isRead : ((n.readBy || []).map(id => id.toString()).includes(typeof user !== 'undefined' ? user._id.toString() : '')); %>
            <div class="notif-item <%= isRead ? 'read' : 'unread' %>" data-id="<%= n._id %>" onclick="markRead('<%= n._id %>')">
              <div class="notif-title" style="<%= isRead ? '' : 'font-weight:700;color:var(--primary);' %>">
                <% const icons = {announcement:'📢',event:'🎉',alert:'⚠️',system:'🔧',payment:'💰',payment_reminder:'⏰'}; %>
                <%= icons[n.type] || '🔔' %> <%= n.title %>
              </div>
              <div class="notif-msg"><%= n.message.length > 80 ? n.message.substring(0, 80) + '…' : n.message %></div>
              <div class="notif-time">
                <%
                  const diff = Math.round((new Date() - new Date(n.createdAt)) / 60000);
                  let tAgo;
                  if (diff < 1) tAgo = 'Just now';
                  else if (diff < 60) tAgo = diff + ' min ago';
                  else if (diff < 1440) tAgo = Math.round(diff/60) + ' hr ago';
                  else tAgo = Math.round(diff/1440) + ' day ago';
                %>
                <%= tAgo %>
              </div>
            </div>
          <% }) %>
          <% if (typeof user !== 'undefined') { %>
            <div style="padding:10px;text-align:center;border-top:1px solid var(--border);">
              <button onclick="markAllRead()" style="background:none;border:none;color:var(--primary);font-size:0.82rem;cursor:pointer;">
                <i class="fas fa-check-double"></i> Mark all as read
              </button>
            </div>
          <% } %>
        <% } %>
      </div>
    </div>
    <% } %>

    <button class="theme-toggle-btn" aria-label="Toggle dark mode" style="margin-right: 0.5rem;">
      <i class="fa-solid fa-moon"></i>
    </button>


    <% if (typeof user !== 'undefined' && user) { %>
      <a href="/profile" class="topbar-avatar" title="<%= user.name %>">
        <% if (user.profileImage) { %>
          <img src="<%= user.profileImage %>" alt="<%= user.name %>" />
        <% } else { %>
          <div class="avatar-initial"><%= user.name.charAt(0).toUpperCase() %></div>
        <% } %>
      </a>
    <% } else if (typeof admin !== 'undefined' && admin) { %>
      <a href="/admin/profile" class="topbar-avatar" title="<%= admin.name %>">
        <% if (admin.profileImage) { %>
          <img src="<%= admin.profileImage %>" alt="<%= admin.name %>" />
        <% } else { %>
          <div class="avatar-initial"><%= admin.name.charAt(0).toUpperCase() %></div>
        <% } %>
      </a>
    <% } %>
  </div>
</header>

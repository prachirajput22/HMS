<%- include('../partials/header') %>
<div class="app-layout">
  <%- include('../partials/adminSidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-content">

      <% if (success && success.length > 0) { %>
        <% success.forEach(s => { %><div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= s %></div><% }) %>
      <% } %>
      <% if (errors && errors.length > 0) { %>
        <% errors.forEach(e => { %><div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= e %></div><% }) %>
      <% } %>

      <!-- Stats Grid -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon blue"><i class="fas fa-users"></i></div>
          <div class="stat-info">
            <h3 data-count="<%= stats.totalStudents %>"><%= stats.totalStudents %></h3>
            <p>Total Students</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon green"><i class="fas fa-user-check"></i></div>
          <div class="stat-info">
            <h3 data-count="<%= stats.allocatedStudents %>"><%= stats.allocatedStudents %></h3>
            <p>Allocated</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon orange"><i class="fas fa-clock"></i></div>
          <div class="stat-info">
            <h3 data-count="<%= stats.waitingCount %>"><%= stats.waitingCount %></h3>
            <p>Waiting List</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon primary"><i class="fas fa-bed"></i></div>
          <div class="stat-info">
            <h3 data-count="<%= stats.totalRooms %>"><%= stats.totalRooms %></h3>
            <p>Total Rooms</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon green"><i class="fas fa-door-open"></i></div>
          <div class="stat-info">
            <h3 data-count="<%= stats.availableRooms %>"><%= stats.availableRooms %></h3>
            <p>Available</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon purple"><i class="fas fa-rupee-sign"></i></div>
          <div class="stat-info">
            <h3>₹<%= stats.totalRevenue ? stats.totalRevenue.toLocaleString() : '0' %></h3>
            <p>Revenue Collected</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon red"><i class="fas fa-exclamation-triangle"></i></div>
          <div class="stat-info">
            <h3 data-count="<%= stats.pendingFees %>"><%= stats.pendingFees %></h3>
            <p>Pending Fees</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon orange"><i class="fas fa-flag"></i></div>
          <div class="stat-info">
            <h3 data-count="<%= stats.openComplaints %>"><%= stats.openComplaints %></h3>
            <p>Open Complaints</p>
          </div>
        </div>
      </div>

      <!-- Waiting Pool & Smart Allocation -->
      <div class="section-header" style="margin-top: 2rem; display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
        <h3><i class="fas fa-users-clock"></i> Waiting Pool</h3>
        <form action="/admin/allocate" method="POST">
          <button type="submit" class="btn btn-primary" <%= typeof waitingUsers !== 'undefined' && waitingUsers.length === 0 ? 'disabled' : '' %>>
            <i class="fas fa-magic"></i> Run Smart Allocation
          </button>
        </form>
      </div>

      <div class="glass-card" style="margin-bottom: 2rem; overflow-x: auto;">
        <table class="table" style="width: 100%; border-collapse: collapse; min-width: 600px;">
          <thead>
            <tr style="border-bottom: 2px solid rgba(0,0,0,0.1); text-align: left;">
              <th style="padding: 12px 10px;">Name</th>
              <th style="padding: 12px 10px;">Email</th>
              <th style="padding: 12px 10px;">Sleep Schedule</th>
              <th style="padding: 12px 10px;">Food Preference</th>
              <th style="padding: 12px 10px;">Lifestyle</th>
            </tr>
          </thead>
          <tbody>
            <% if (typeof waitingUsers !== 'undefined' && waitingUsers.length > 0) { %>
              <% waitingUsers.forEach(u => { %>
                <tr style="border-bottom: 1px solid rgba(0,0,0,0.05);">
                  <td style="padding: 12px 10px; font-weight: 500;"><%= u.name %></td>
                  <td style="padding: 12px 10px; color: var(--text-muted);"><%= u.email %></td>
                  <td style="padding: 12px 10px;"><span class="badge badge-info"><%= u.preferences.sleepSchedule %></span></td>
                  <td style="padding: 12px 10px;"><span class="badge badge-success"><%= u.preferences.food %></span></td>
                  <td style="padding: 12px 10px;"><span class="badge badge-warning"><%= u.preferences.lifestyle %></span></td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="5" style="padding: 30px; text-align: center; color: var(--text-muted);">
                  <i class="fas fa-check-circle" style="color: var(--success); font-size: 1.5rem; margin-bottom: 0.5rem; display: block;"></i>
                  No users are currently waiting for room allocation.
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <!-- Room-wise Occupancy Tracking -->
      <div class="section-header" style="margin-top: 2rem; margin-bottom: 1rem;">
        <h3><i class="fas fa-bed"></i> Room-wise Occupancy</h3>
      </div>
      <div class="glass-card" style="margin-bottom: 2rem; overflow-x: auto;">
        <table class="table" style="width: 100%; border-collapse: collapse; min-width: 600px;">
          <thead>
            <tr style="border-bottom: 2px solid rgba(0,0,0,0.1); text-align: left;">
              <th style="padding: 12px 10px;">Room Info</th>
              <th style="padding: 12px 10px;">Capacity</th>
              <th style="padding: 12px 10px;">Current Occupants</th>
              <th style="padding: 12px 10px;">Status</th>
            </tr>
          </thead>
          <tbody>
            <% if (typeof roomsWithOccupants !== 'undefined' && roomsWithOccupants.length > 0) { %>
              <% roomsWithOccupants.forEach(room => { %>
                <tr style="border-bottom: 1px solid rgba(0,0,0,0.05);">
                  <td style="padding: 12px 10px; font-weight: 500;">
                    Room <%= room.roomNumber %> <br>
                    <small class="text-muted">Floor <%= room.floor %></small>
                  </td>
                  <td style="padding: 12px 10px;">
                    <span class="badge <%= room.occupants.length >= room.capacity ? 'badge-danger' : (room.occupants.length > 0 ? 'badge-warning' : 'badge-success') %>">
                      <%= room.occupants.length %> / <%= room.capacity %>
                    </span>
                  </td>
                  <td style="padding: 12px 10px;">
                    <% if (room.occupants.length > 0) { %>
                      <div style="display:flex; flex-direction:column; gap:4px;">
                      <% room.occupants.forEach(occ => { %>
                        <div style="font-size:0.9rem;">
                          <i class="fas fa-user" style="color:var(--primary); font-size:0.8rem; margin-right:4px;"></i> <%= occ.name %>
                          <span style="font-size:0.8rem; color:var(--text-muted); margin-left:4px;">
                            [<%= occ.preferences.sleepSchedule.charAt(0) %>|<%= occ.preferences.food.charAt(0) %>|<%= occ.preferences.lifestyle.charAt(0) %>]
                          </span>
                        </div>
                      <% }) %>
                      </div>
                    <% } else { %>
                      <span class="text-muted"><i class="fas fa-ghost"></i> Currently Empty</span>
                    <% } %>
                  </td>
                  <td style="padding: 12px 10px;">
                    <span class="badge <%= room.status === 'Available' ? 'badge-success' : (room.status === 'Full' ? 'badge-danger' : 'badge-warning') %>"><%= room.status %></span>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="4" style="padding: 30px; text-align: center; color: var(--text-muted);">
                  No rooms exist in the directory.
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <!-- Charts -->
      <div class="chart-grid">
        <div class="chart-card">
          <h3><i class="fas fa-chart-pie"></i> Room Occupancy</h3>
          <canvas id="occupancyChart"></canvas>
        </div>
        <div class="chart-card">
          <h3><i class="fas fa-chart-bar"></i> Payment Status</h3>
          <canvas id="paymentChart"></canvas>
        </div>
      </div>

      <script>
        document.addEventListener('DOMContentLoaded', function() {
          var chartData = <%- chartData %>;

          // Occupancy Pie Chart
          var ctx1 = document.getElementById('occupancyChart');
          if (ctx1) {
            new Chart(ctx1, {
              type: 'doughnut',
              data: {
                labels: chartData.occupancy.labels,
                datasets: [{
                  data: chartData.occupancy.data,
                  backgroundColor: ['#1e293b', '#334155', '#f97316', '#ef4444'],
                  borderWidth: 0,
                  spacing: 2,
                  borderRadius: 4,
                }]
              },
              options: {
                responsive: true,
                plugins: {
                  legend: { position: 'bottom', labels: { padding: 16, usePointStyle: true, font: { family: 'Inter', size: 12 } } }
                },
                cutout: '65%',
              }
            });
          }

          // Payment Bar Chart
          var ctx2 = document.getElementById('paymentChart');
          if (ctx2) {
            new Chart(ctx2, {
              type: 'bar',
              data: {
                labels: chartData.payments.labels,
                datasets: [{
                  label: 'Count',
                  data: chartData.payments.data,
                  backgroundColor: ['#1e293b', '#f97316'],
                  borderRadius: 8,
                  borderSkipped: false,
                }]
              },
              options: {
                responsive: true,
                plugins: {
                  legend: { display: false }
                },
                scales: {
                  y: { beginAtZero: true, grid: { display: false }, ticks: { font: { family: 'Inter' } } },
                  x: { grid: { display: false }, ticks: { font: { family: 'Inter' } } }
                }
              }
            });
          }
        });
      </script>

    </div>
  </div>
</div>
<%- include('../partials/footer') %>

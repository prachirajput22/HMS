<%- include('../partials/header') %>
<div class="app-layout">
  <%- include('../partials/adminSidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-content">

      <!-- Average Rating -->
      <div class="stats-grid" style="grid-template-columns:repeat(auto-fill,minmax(200px,1fr));">
        <div class="stat-card">
          <div class="stat-icon orange"><i class="fas fa-star"></i></div>
          <div class="stat-info">
            <h3><%= avgRating %>/5</h3>
            <p>Average Rating</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon blue"><i class="fas fa-comments"></i></div>
          <div class="stat-info">
            <h3><%= feedbacks.length %></h3>
            <p>Total Responses</p>
          </div>
        </div>
      </div>

      <!-- Feedback List -->
      <div class="section-header">
        <h3><i class="fas fa-star"></i> All Feedback</h3>
      </div>
      <% if (feedbacks.length === 0) { %>
        <div class="empty-state"><i class="fas fa-star"></i><h4>No Feedback Yet</h4></div>
      <% } else { %>
        <div class="complaint-grid">
          <% feedbacks.forEach(fb => { %>
            <div class="glass-card">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
                <div>
                  <strong><%= fb.userId ? fb.userId.name : 'Unknown' %></strong>
                  <br><small class="text-muted"><%= fb.userId ? fb.userId.email : '' %></small>
                </div>
                <div style="color:var(--warning);font-size:1.1rem;">
                  <% for (let i = 1; i <= 5; i++) { %>
                    <i class="fas fa-star" style="opacity:<%= i <= fb.rating ? '1' : '0.2' %>"></i>
                  <% } %>
                </div>
              </div>
              <% if (fb.comment) { %>
                <p style="font-size:0.88rem;color:var(--text-secondary);line-height:1.6;"><%= fb.comment %></p>
              <% } %>
              <small class="text-muted"><%= new Date(fb.createdAt).toLocaleDateString('en-IN') %></small>
            </div>
          <% }) %>
        </div>
      <% } %>

    </div>
  </div>
</div>
<%- include('../partials/footer') %>

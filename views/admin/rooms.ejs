<%- include('../partials/header') %>
<div class="app-layout">
  <%- include('../partials/adminSidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-content">

      <% if (success && success.length > 0) { %>
        <% success.forEach(s => { %><div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= s %></div><% }) %>
      <% } %>
      <% if (errors && errors.length > 0) { %>
        <% errors.forEach(e => { %><div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= e %></div><% }) %>
      <% } %>

      <!-- Page Header -->
      <div class="rooms-page-header">
        <div>
          <h1 class="rooms-page-title"><i class="fas fa-bed"></i> Room Management</h1>
          <p class="rooms-page-sub">Manage all hostel rooms, capacity, and assignments</p>
        </div>
        <button class="btn btn-primary" onclick="openModal('addRoomModal')">
          <i class="fas fa-plus"></i> Add Room
        </button>
      </div>

      <!-- Stats Bar -->
      <div class="rooms-stats-bar">
        <div class="rstat-card">
          <div class="rstat-icon primary"><i class="fas fa-building"></i></div>
          <div class="rstat-info">
            <div class="rstat-num"><%= stats.total %></div>
            <div class="rstat-lbl">Total Rooms</div>
          </div>
        </div>
        <div class="rstat-card">
          <div class="rstat-icon green"><i class="fas fa-door-open"></i></div>
          <div class="rstat-info">
            <div class="rstat-num"><%= stats.available %></div>
            <div class="rstat-lbl">Available</div>
          </div>
        </div>
        <div class="rstat-card">
          <div class="rstat-icon red"><i class="fas fa-users"></i></div>
          <div class="rstat-info">
            <div class="rstat-num"><%= stats.full %></div>
            <div class="rstat-lbl">Full</div>
          </div>
        </div>
        <div class="rstat-card">
          <div class="rstat-icon orange"><i class="fas fa-wrench"></i></div>
          <div class="rstat-info">
            <div class="rstat-num"><%= stats.maintenance %></div>
            <div class="rstat-lbl">Maintenance</div>
          </div>
        </div>
      </div>

      <!-- Filter Bar -->
      <div class="rooms-filter-bar">
        <div class="rooms-search-wrap">
          <i class="fas fa-search"></i>
          <input type="text" id="roomSearch" placeholder="Search room number, floor, block..." class="rooms-search-input" oninput="filterRooms()">
        </div>
        <div class="rooms-filter-btns">
          <button class="filter-btn active" data-filter="All" onclick="setFilter(this,'All')">All</button>
          <button class="filter-btn" data-filter="Available" onclick="setFilter(this,'Available')">Available</button>
          <button class="filter-btn" data-filter="Full" onclick="setFilter(this,'Full')">Full</button>
          <button class="filter-btn" data-filter="Maintenance" onclick="setFilter(this,'Maintenance')">Maintenance</button>
        </div>
      </div>

      <!-- Room Grid -->
      <% if (rooms.length === 0) { %>
        <div class="empty-state">
          <i class="fas fa-building"></i>
          <h4>No Rooms Yet</h4>
          <p>Add the first hostel room to get started.</p>
          <button class="btn btn-primary mt-2" onclick="openModal('addRoomModal')"><i class="fas fa-plus"></i> Add Room</button>
        </div>
      <% } else { %>
        <div class="rooms-grid" id="roomsGrid">
          <% rooms.forEach(room => { %>
            <div class="room-pro-card"
                 data-status="<%= room.status %>"
                 data-search="<%= room.roomNumber %> <%= room.floor %> <%= room.block || 'A' %>">
              <!-- Card header with status badge -->
              <div class="room-pro-header">
                <div class="room-pro-number">
                  <i class="fas fa-door-open"></i>
                  <span>Room <strong><%= room.roomNumber %></strong></span>
                </div>
                <span class="badge badge-<%= room.status === 'Available' ? 'success' : (room.status === 'Full' ? 'danger' : 'warning') %>">
                  <span class="status-dot-mini <%= room.status.toLowerCase() %>"></span>
                  <%= room.status %>
                </span>
              </div>

              <!-- Occupancy bar -->
              <div class="room-occ-section">
                <div class="room-occ-label">
                  <span>Occupancy</span>
                  <span><strong><%= room.occupants.length %></strong> / <%= room.capacity %></span>
                </div>
                <div class="room-occ-bar">
                  <div class="room-occ-fill
                    <%= room.occupants.length >= room.capacity ? 'occ-full' : (room.occupants.length > 0 ? 'occ-partial' : 'occ-empty') %>"
                    style="width:<%= Math.round((room.occupants.length / room.capacity) * 100) %>%">
                  </div>
                </div>
                <div class="room-occ-slots">
                  <% const free = room.capacity - room.occupants.length; %>
                  <span class="<%= free > 0 ? 'text-success' : 'text-danger' %>">
                    <%= free %> bed<%= free !== 1 ? 's' : '' %> free
                  </span>
                </div>
              </div>

              <!-- Info Pills -->
              <div class="room-info-pills">
                <span class="room-pill"><i class="fas fa-layer-group"></i> Floor <%= room.floor %></span>
                <span class="room-pill"><i class="fas fa-cube"></i> Block <%= room.block || 'A' %></span>
                <span class="room-pill type-pill"><%= room.type || 'Double' %></span>
                <span class="room-pill fee-pill"><i class="fas fa-rupee-sign"></i><%= room.monthlyFee %>/mo</span>
              </div>

              <!-- Amenities -->
              <% if (room.amenities && room.amenities.length > 0) { %>
                <div class="room-amenities">
                  <% room.amenities.slice(0,4).forEach(a => { %>
                    <span class="amenity-tag"><i class="fas fa-check-circle"></i> <%= a %></span>
                  <% }) %>
                  <% if (room.amenities.length > 4) { %><span class="amenity-tag">+<%= room.amenities.length - 4 %> more</span><% } %>
                </div>
              <% } %>

              <!-- Occupants -->
              <% if (room.occupants.length > 0) { %>
                <div class="room-occupants-section">
                  <div class="room-occ-title"><i class="fas fa-users"></i> Residents</div>
                  <div class="room-occ-tags">
                    <% room.occupants.forEach(occ => { %>
                      <span class="occ-tag">
                        <span class="occ-avatar"><%= occ.name.charAt(0).toUpperCase() %></span>
                        <%= occ.name %>
                      </span>
                    <% }) %>
                  </div>
                </div>
              <% } %>

              <!-- Actions -->
              <div class="room-pro-actions">
                <button class="btn btn-sm btn-secondary"
                  onclick="openEditModal({
                    id:'<%= room._id %>',
                    roomNumber:'<%= room.roomNumber %>',
                    floor:<%= room.floor %>,
                    block:'<%= room.block || 'A' %>',
                    type:'<%= room.type || 'Double' %>',
                    capacity:<%= room.capacity %>,
                    status:'<%= room.status %>',
                    monthlyFee:<%= room.monthlyFee %>,
                    amenities:'<%= (room.amenities || []).join(', ') %>'
                  })">
                  <i class="fas fa-edit"></i> Edit
                </button>
                <% if (room.occupants.length === 0) { %>
                  <form action="/admin/rooms/<%= room._id %>/delete" method="POST"
                        style="display:inline;" onsubmit="return confirm('Delete Room <%= room.roomNumber %>?')">
                    <button type="submit" class="btn btn-sm btn-danger">
                      <i class="fas fa-trash"></i>
                    </button>
                  </form>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>

      <!-- Add Room Modal -->
      <div id="addRoomModal" class="modal-overlay hidden">
        <div class="modal-content" style="max-width:520px;">
          <div class="modal-header">
            <h3><i class="fas fa-plus-circle" style="color:var(--primary)"></i> Add New Room</h3>
            <button class="modal-close" onclick="closeModal('addRoomModal')">&times;</button>
          </div>
          <form action="/admin/rooms" method="POST">
            <div class="form-row">
              <div class="form-group">
                <label for="roomNumber">Room Number</label>
                <input type="text" id="roomNumber" name="roomNumber" class="form-control" placeholder="e.g., 101" required />
              </div>
              <div class="form-group">
                <label for="floor">Floor</label>
                <input type="number" id="floor" name="floor" class="form-control" min="0" placeholder="1" required />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="block">Block</label>
                <input type="text" id="block" name="block" class="form-control" placeholder="A" />
              </div>
              <div class="form-group">
                <label for="type">Room Type</label>
                <select id="type" name="type" class="form-control">
                  <option value="Single">Single</option>
                  <option value="Double" selected>Double</option>
                  <option value="Triple">Triple</option>
                  <option value="Dormitory">Dormitory</option>
                </select>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="capacity">Capacity</label>
                <input type="number" id="capacity" name="capacity" class="form-control" min="1" value="2" required />
              </div>
              <div class="form-group">
                <label for="monthlyFee">Monthly Fee (₹)</label>
                <input type="number" id="monthlyFee" name="monthlyFee" class="form-control" value="5000" required />
              </div>
            </div>
            <div class="form-group">
              <label for="amenities">Amenities <small style="font-weight:400;color:var(--text-muted)">(comma-separated)</small></label>
              <input type="text" id="amenities" name="amenities" class="form-control" placeholder="AC, WiFi, Attached Bath" />
            </div>
            <button type="submit" class="btn btn-primary btn-block">
              <i class="fas fa-plus"></i> Create Room
            </button>
          </form>
        </div>
      </div>

      <!-- Edit Room Modal -->
      <div id="editRoomModal" class="modal-overlay hidden">
        <div class="modal-content" style="max-width:520px;">
          <div class="modal-header">
            <h3><i class="fas fa-edit" style="color:var(--primary)"></i> Edit Room</h3>
            <button class="modal-close" onclick="closeModal('editRoomModal')">&times;</button>
          </div>
          <form id="editRoomForm" action="" method="POST">
            <div class="form-row">
              <div class="form-group">
                <label for="editRoomNumber">Room Number</label>
                <input type="text" id="editRoomNumber" name="roomNumber" class="form-control" required />
              </div>
              <div class="form-group">
                <label for="editFloor">Floor</label>
                <input type="number" id="editFloor" name="floor" class="form-control" min="0" required />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="editBlock">Block</label>
                <input type="text" id="editBlock" name="block" class="form-control" />
              </div>
              <div class="form-group">
                <label for="editType">Room Type</label>
                <select id="editType" name="type" class="form-control">
                  <option value="Single">Single</option>
                  <option value="Double">Double</option>
                  <option value="Triple">Triple</option>
                  <option value="Dormitory">Dormitory</option>
                </select>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="editCapacity">Capacity</label>
                <input type="number" id="editCapacity" name="capacity" class="form-control" min="1" required />
              </div>
              <div class="form-group">
                <label for="editMonthlyFee">Monthly Fee (₹)</label>
                <input type="number" id="editMonthlyFee" name="monthlyFee" class="form-control" required />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="editStatus">Status</label>
                <select id="editStatus" name="status" class="form-control">
                  <option value="Available">Available</option>
                  <option value="Full">Full</option>
                  <option value="Maintenance">Maintenance</option>
                </select>
              </div>
              <div class="form-group">
                <label for="editAmenities">Amenities</label>
                <input type="text" id="editAmenities" name="amenities" class="form-control" placeholder="AC, WiFi" />
              </div>
            </div>
            <button type="submit" class="btn btn-primary btn-block">
              <i class="fas fa-save"></i> Update Room
            </button>
          </form>
        </div>
      </div>

    </div>
  </div>
</div>
<%- include('../partials/footer') %>

<script>
function openModal(id) { document.getElementById(id).classList.remove('hidden'); }
function closeModal(id) { document.getElementById(id).classList.add('hidden'); }

function openEditModal(data) {
  document.getElementById('editRoomForm').action = '/admin/rooms/' + data.id + '/update';
  document.getElementById('editRoomNumber').value = data.roomNumber;
  document.getElementById('editFloor').value = data.floor;
  document.getElementById('editBlock').value = data.block || 'A';
  document.getElementById('editType').value = data.type || 'Double';
  document.getElementById('editCapacity').value = data.capacity;
  document.getElementById('editMonthlyFee').value = data.monthlyFee;
  document.getElementById('editStatus').value = data.status;
  document.getElementById('editAmenities').value = data.amenities || '';
  openModal('editRoomModal');
}

let currentFilter = 'All';

function setFilter(btn, status) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  currentFilter = status;
  filterRooms();
}

function filterRooms() {
  const q = document.getElementById('roomSearch').value.toLowerCase();
  document.querySelectorAll('.room-pro-card').forEach(card => {
    const statusMatch = currentFilter === 'All' || card.dataset.status === currentFilter;
    const searchMatch = !q || card.dataset.search.toLowerCase().includes(q);
    card.style.display = statusMatch && searchMatch ? '' : 'none';
  });
}
</script>

<%- include('../partials/header') %>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-header">
      <div class="auth-logo"><i class="fas fa-shield-alt"></i></div>
      <h2>Admin Login</h2>
      <p class="auth-subtitle">MITS Hostel Management — Admin Panel</p>
    </div>

    <% if (errors && errors.length > 0) { %>
      <% errors.forEach(e => { %>
        <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= e %></div>
      <% }) %>
    <% } %>
    <% if (success && success.length > 0) { %>
      <% success.forEach(s => { %>
        <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= s %></div>
      <% }) %>
    <% } %>

    <form action="/admin/login" method="POST">
      <div class="form-group">
        <label for="email"><i class="fas fa-envelope"></i> Admin Email</label>
        <input type="email" id="email" name="email" class="form-control" placeholder="admin@mits.com" required autofocus />
      </div>
      <div class="form-group">
        <label for="password"><i class="fas fa-lock"></i> Password</label>
        <input type="password" id="password" name="password" class="form-control" placeholder="••••••••" required />
      </div>
      <button type="submit" class="btn btn-primary btn-block btn-lg">
        <i class="fas fa-shield-alt"></i> Admin Sign In
      </button>
    </form>

    <div class="auth-footer" style="display:flex; justify-content:space-between; align-items:center;">
      <a href="/login">← Back to Student Login</a>
      <a href="/admin/register" style="color:var(--primary); font-weight:600;">Register new Admin</a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

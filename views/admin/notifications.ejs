<%- include('../partials/header') %>
<div class="app-layout">
  <%- include('../partials/adminSidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-content">

      <% if (success && success.length > 0) { %>
        <% success.forEach(s => { %><div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= s %></div><% }) %>
      <% } %>
      <% if (errors && errors.length > 0) { %>
        <% errors.forEach(e => { %><div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= e %></div><% }) %>
      <% } %>

      <!-- Send Notification -->
      <div class="glass-card mb-3">
        <h3 style="margin-bottom:1rem;"><i class="fas fa-bullhorn" style="color:var(--primary)"></i> Send Notification</h3>
        <form action="/admin/notifications" method="POST">
          <div class="form-row">
            <div class="form-group">
              <label for="notifTitle">Title</label>
              <input type="text" id="notifTitle" name="title" class="form-control" placeholder="Notification title..." required />
            </div>
            <div class="form-group">
              <label for="notifType">Type</label>
              <select id="notifType" name="type" class="form-control">
                <option value="announcement">📢 Announcement</option>
                <option value="event">🎉 Event</option>
                <option value="alert">⚠️ Alert</option>
                <option value="system">🔧 System</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label for="notifMessage">Message</label>
            <textarea id="notifMessage" name="message" class="form-control" placeholder="Write your notification..." required></textarea>
          </div>
          <button type="submit" class="btn btn-primary">
            <i class="fas fa-paper-plane"></i> Send to All Users
          </button>
        </form>
      </div>

      <!-- History -->
      <div class="section-header">
        <h3><i class="fas fa-history"></i> Notification History</h3>
      </div>
      <% if (notifications.length === 0) { %>
        <div class="empty-state"><i class="fas fa-bell-slash"></i><h4>No Notifications</h4></div>
      <% } else { %>
        <div class="notif-list">
          <% notifications.forEach(n => { %>
            <div class="notif-card">
              <div class="notif-content">
                <h4><%= n.title %></h4>
                <p><%= n.message %></p>
                <div class="notif-meta">
                  <span class="badge badge-<%= n.type === 'alert' ? 'warning' : (n.type === 'event' ? 'success' : 'info') %>"><%= n.type %></span>
                  &nbsp; <%= new Date(n.createdAt).toLocaleDateString('en-IN') %> at <%= new Date(n.createdAt).toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit'}) %>
                </div>
              </div>
              <form action="/admin/notifications/<%= n._id %>/delete" method="POST" onsubmit="return confirm('Delete this notification?')">
                <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
              </form>
            </div>
          <% }) %>
        </div>
      <% } %>

    </div>
  </div>
</div>
<%- include('../partials/footer') %>

<%- include('../partials/header') %>
<div class="app-layout">
  <%- include('../partials/adminSidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-content">

      <% if (success && success.length > 0) { %>
        <% success.forEach(s => { %><div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= s %></div><% }) %>
      <% } %>
      <% if (errors && errors.length > 0) { %>
        <% errors.forEach(e => { %><div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= e %></div><% }) %>
      <% } %>

      <!-- Send Notification -->
      <div class="glass-card mb-3">
        <h3 style="margin-bottom:1.2rem;display:flex;align-items:center;gap:8px;">
          <i class="fas fa-bullhorn" style="color:var(--primary)"></i> Send Notification
        </h3>
        <form action="/admin/notifications" method="POST">
          <div class="form-row">
            <div class="form-group">
              <label for="notifTitle">Title</label>
              <input type="text" id="notifTitle" name="title" class="form-control" placeholder="Notification title..." required />
            </div>
            <div class="form-group">
              <label for="notifType">Type</label>
              <select id="notifType" name="type" class="form-control">
                <option value="announcement">📢 Announcement</option>
                <option value="event">🎉 Event</option>
                <option value="alert">⚠️ Alert</option>
                <option value="system">🔧 System</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label for="targetUserId">Send To</label>
            <select id="targetUserId" name="targetUserId" class="form-control">
              <option value="all">📣 All Users (Broadcast)</option>
              <% users.forEach(u => { %>
                <option value="<%= u._id %>"><%= u.name %> — <%= u.email %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label for="notifMessage">Message</label>
            <textarea id="notifMessage" name="message" class="form-control" rows="3" placeholder="Write your notification message..." required></textarea>
          </div>
          <button type="submit" class="btn btn-primary">
            <i class="fas fa-paper-plane"></i> Send Notification
          </button>
        </form>
      </div>

      <!-- Filter Tabs -->
      <div class="section-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;margin-bottom:1rem;">
        <h3 style="margin:0;"><i class="fas fa-history"></i> Notification History</h3>
        <div style="display:flex;gap:8px;">
          <button class="btn btn-sm" id="filterAll" onclick="filterNotifs('all')" style="background:var(--primary);color:#fff;">All</button>
          <button class="btn btn-sm" id="filterBroadcast" onclick="filterNotifs('broadcast')">Broadcast</button>
          <button class="btn btn-sm" id="filterPersonal" onclick="filterNotifs('personal')">Personal</button>
        </div>
      </div>

      <% if (notifications.length === 0) { %>
        <div class="empty-state glass-card">
          <i class="fas fa-bell-slash"></i>
          <h4>No Notifications Sent Yet</h4>
          <p>Use the form above to send your first notification.</p>
        </div>
      <% } else { %>
        <div class="notif-list" id="notifList">
          <% notifications.forEach(n => { %>
            <div class="notif-card glass-card" data-target="<%= n.userId ? 'personal' : 'broadcast' %>" style="margin-bottom:0.8rem;">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
                <div style="flex:1;">
                  <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
                    <% const iconMap = { announcement:'📢', event:'🎉', alert:'⚠️', system:'🔧', payment:'💰', payment_reminder:'⏰' }; %>
                    <span style="font-size:1.1rem;"><%= iconMap[n.type] || '🔔' %></span>
                    <strong><%= n.title %></strong>
                    <span class="badge badge-<%= n.userId ? 'warning' : 'info' %>" style="font-size:0.72rem;">
                      <%= n.userId ? 'Personal → ' + (n.userId.name || 'User') : 'Broadcast' %>
                    </span>
                  </div>
                  <p style="margin:0 0 6px;color:var(--text-secondary);font-size:0.9rem;"><%= n.message %></p>
                  <span style="font-size:0.78rem;color:var(--text-muted);">
                    <i class="fas fa-clock"></i>
                    <%= new Date(n.createdAt).toLocaleDateString('en-IN') %> at
                    <%= new Date(n.createdAt).toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit'}) %>
                  </span>
                </div>
                <form action="/admin/notifications/<%= n._id %>/delete" method="POST" onsubmit="return confirm('Delete this notification?')" style="flex-shrink:0;">
                  <button type="submit" class="btn btn-sm" style="background:var(--danger);color:#fff;" title="Delete">
                    <i class="fas fa-trash"></i>
                  </button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>

    </div>
  </div>
</div>

<script>
function filterNotifs(type) {
  document.querySelectorAll('#notifList .notif-card').forEach(card => {
    if (type === 'all' || card.dataset.target === type) {
      card.style.display = '';
    } else {
      card.style.display = 'none';
    }
  });
  document.querySelectorAll('[id^="filter"]').forEach(btn => btn.style.background = '');
  document.getElementById('filter' + type.charAt(0).toUpperCase() + type.slice(1)).style.background = 'var(--primary)';
  document.getElementById('filter' + type.charAt(0).toUpperCase() + type.slice(1)).style.color = '#fff';
}
</script>

<%- include('../partials/footer') %>
